{
  "name": "titanbay-api",
  "version": "1.0.0",
  "description": "Private market funds and investor commitments API",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "audit:check": "npm audit --audit-level=high",
    "audit:full": "npm audit --audit-level=medium",
    "format": "biome format --write .",
    "test": "biome check . && vitest run",
    "test:watch": "vitest",
    "db:migrate": "drizzle-kit migrate",
    "db:seed": "tsx scripts/seed.ts",
    "db:generate": "drizzle-kit generate",
    "prepare": "[ -d .git ] && husky || true"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/jwt": "^10.1.0",
    "@fastify/rate-limit": "^11.0.0",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^6.0.0",
    "bcryptjs": "^3.0.3",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "fastify": "^5.8.5",
    "fastify-type-provider-zod": "^6.1.0",
    "husky": "^9.1.7",
    "postgres": "^3.4.9",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "@types/bcryptjs": "^3.0.0",
    "@types/node": "^25.9.3",
    "@types/supertest": "^7.2.0",
    "drizzle-kit": "^0.31.10",
    "lint-staged": "^17.0.7",
    "supertest": "^7.2.2",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "lint-staged": {
    "*.ts": [
      "biome check --write"
    ]
  }
}
